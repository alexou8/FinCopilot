{
  "name": "fincopilot",
  "version": "1.0.0",
  "description": "Conversational finance copilot for students that builds a live financial profile, flags critical money issues, and runs what-if scenarios to help users make better decisions.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"uvicorn backend.main:app --reload --port 8000\" \"npm run dev --prefix frontend\"",
    "start": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"uvicorn backend.main:app --port 8000\" \"npm run start --prefix frontend\"",
    "build": "npm run build --prefix frontend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexou8/FinCopilot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alexou8/FinCopilot/issues"
  },
  "homepage": "https://github.com/alexou8/FinCopilot#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
